{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlcai.org/schemas/schedule.schema.json",
  "title": "SDLCAI schedule",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time", "title", "body"],
        "additionalProperties": false,
        "properties": {
          "time": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]-([01][0-9]|2[0-3]):[0-5][0-9]$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
