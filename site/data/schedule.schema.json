{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlcai.org/schemas/schedule.schema.json",
  "title": "SDLCAI schedule",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time", "title", "body"],
        "additionalProperties": false,
        "properties": {
          "time": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]-([01][0-9]|2[0-3]):[0-5][0-9]$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "talks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["time", "title", "abstract", "speaker"],
              "additionalProperties": false,
              "properties": {
                "time": {
                  "type": "string",
                  "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]-([01][0-9]|2[0-3]):[0-5][0-9]$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "abstract": {
                  "type": "string",
                  "minLength": 1
                },
                "speaker": {
                  "type": "object",
                  "required": ["name", "role", "bio"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "role": {
                      "type": "string",
                      "minLength": 1
                    },
                    "photo": {
                      "type": "string",
                      "pattern": "^/assets/.+\\.(webp|png|jpg|jpeg)$"
                    },
                    "website": {
                      "type": "string",
                      "format": "uri"
                    },
                    "scholar": {
                      "type": "string",
                      "format": "uri"
                    },
                    "bio": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
