{
  "name": "ai-meets-sdlc",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "gustwind --build --output ./build --no-incremental",
    "a11y:check": "node scripts/validate-a11y.mjs",
    "data:validate": "node scripts/validate-data.mjs",
    "db:migrate:local": "wrangler d1 migrations apply ai-meets-sdlc-interests --local",
    "db:migrate:remote": "wrangler d1 migrations apply ai-meets-sdlc-interests --remote",
    "dev:env": "node scripts/write-dev-vars.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "interests:decrypt": "node scripts/decrypt-interests.mjs",
    "interests:export": "node scripts/export-interest-contacts.mjs",
    "layout:check": "node scripts/validate-layout.mjs",
    "layout:install-browsers": "playwright install webkit",
    "quality:gate": "npm run worker:build && npm run validate && npm run layout:check && npm run a11y:check",
    "start": "gustwind --develop --port 3000",
    "serve": "gustwind --serve --port 3000 --input ./build",
    "types:check": "tsc --noEmit",
    "types:generate": "wrangler types worker-configuration.d.ts",
    "validate": "npm run data:validate && gustwind --validate --input ./build",
    "worker:build": "npm run types:check && npm run build && node scripts/verify-build-output.mjs",
    "worker:dev": "npm run dev:env && npm run worker:build && wrangler dev",
    "deploy": "npm run worker:build && wrangler deploy"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@tailwindcss/typography": "0.5.19",
    "gustwind": "0.131.0",
    "marked": "18.0.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "axe-core": "4.12.1",
    "dotenv": "17.4.2",
    "playwright": "1.61.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "wrangler": "4.86.0"
  }
}
