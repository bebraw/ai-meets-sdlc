# Copy to .env for local Worker testing.
#
# Generate a strong value, for example:
# openssl rand -base64 32
EMAIL_ENCRYPTION_KEY=replace-with-local-development-secret

# Optional locally. If left empty, the Worker skips Turnstile verification.
TURNSTILE_SECRET_KEY=

# Optional locally. If left empty, the form hides the Turnstile widget.
TURNSTILE_SITE_KEY=

# Required before ticket checkout can create Stripe Checkout Sessions.
CHECKOUTS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_TICKET_TIERS_JSON='[{"id":"early","label":"Early bird","price_id":"price_early_test","price_label":"EUR 199","discount_coupon_id":"coupon_early_test","capacity":40,"available_until":"2026-07-31T20:59:59Z","sort_order":1},{"id":"regular","label":"Regular","price_id":"price_regular_test","price_label":"EUR 299","capacity":80,"available_from":"2026-08-01T00:00:00Z","available_until":"2026-09-30T20:59:59Z","sort_order":2},{"id":"late","label":"Late bird","price_id":"price_late_test","price_label":"EUR 399","capacity":30,"available_from":"2026-10-01T00:00:00Z","sort_order":3}]'
STRIPE_WEBHOOK_SECRET=

# Optional overrides. Defaults use the current request origin.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
