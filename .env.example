# Copy to .env for local Worker testing.
#
# Generate a strong value, for example:
# openssl rand -base64 32
EMAIL_ENCRYPTION_KEY=replace-with-local-development-secret

# Required for /admin and /api/admin/*.
ADMIN_PASSWORD=replace-with-local-admin-password

# Optional locally. If left empty, the Worker skips Turnstile verification.
TURNSTILE_SECRET_KEY=

# Optional locally. If left empty, the form hides the Turnstile widget.
TURNSTILE_SITE_KEY=

# Required before ticket checkout can create Stripe Checkout Sessions.
CHECKOUTS_ENABLED=false
CFP_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional overrides. Defaults use the current request origin.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
